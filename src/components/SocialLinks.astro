---
const socials = [
  { name: 'YouTube', url: 'https://www.youtube.com/c/OfficialNugzzCrew', icon: 'youtube' },
  { name: 'Twitch', url: 'https://www.twitch.tv/officialnugzzcrew', icon: 'twitch' },
  { name: 'Kick', url: 'https://kick.com/officialnugzzcrew', icon: 'play' }, 
  { name: 'Discord', url: 'https://discord.gg/officialnugzzcrew', icon: 'message-square' },
  { name: 'TikTok', url: 'https://www.tiktok.com/@officialnugzzcrew', icon: 'music' },
  { name: 'Instagram', url: 'https://www.instagram.com/officialnugzzcrew', icon: 'instagram' },
  { name: 'X', url: 'https://x.com/NugzzCrew', icon: 'twitter' },
  { name: 'Facebook', url: 'https://www.facebook.com/nugzzcrew', icon: 'facebook' },
  { name: 'Snapchat', url: 'https://www.snapchat.com/add/nugzzcrew', icon: 'ghost' },
  { name: 'Shop', url: 'https://officialnugzzcrew-shop.fourthwall.com', icon: 'shopping-bag' },
  { name: 'Crew', url: 'https://socialclub.rockstargames.com/crew/official_nugzz_crew', icon: 'users' },
];
---

<div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-4 my-12">
  {socials.map((social) => (
    <a 
      href={social.url} 
      target="_blank" 
      rel="noopener noreferrer"
      class="flex flex-col items-center justify-center p-6 bg-zinc-900/50 border border-zinc-800 rounded-xl hover:border-gold hover:bg-zinc-900 transition-all group"
    >
      {/* Added 'lucide' as a class and kept the data attribute */}
      <i data-lucide={social.icon} class="lucide w-8 h-8 text-zinc-500 group-hover:text-gold mb-3 transition-colors"></i>
      <span class="text-[10px] uppercase text-zinc-500 group-hover:text-gold font-bold tracking-widest text-center">
        {social.name}
      </span>
    </a>
  ))}
</div>