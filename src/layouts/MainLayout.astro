---
interface Props {
  title: string;
}

const { title } = Astro.props;
import '../styles/global.css'; 

const socials = [
  { name: 'YouTube', url: 'https://www.youtube.com/@OfficialNugzzCrew/join?app=desktop&action=join', si: 'si-youtube' },
  { name: 'Twitch', url: 'https://www.twitch.tv/officialnugzzcrew', si: 'si-twitch' },
  { name: 'Kick', url: 'https://kick.com/officialnugzzcrew', si: 'si-kick' }, 
  { name: 'Discord', url: 'https://discord.gg/officialnugzzcrew', si: 'si-discord' },
  { name: 'TikTok', url: 'https://www.tiktok.com/@officialnugzzcrew', si: 'si-tiktok' },
  { name: 'Instagram', url: 'https://www.instagram.com/officialnugzzcrew', si: 'si-instagram' },
  { name: 'X', url: 'https://x.com/NugzzCrew', si: 'si-x' },
  { name: 'Facebook', url: 'https://www.facebook.com/nugzzcrew', si: 'si-facebook' },
  { name: 'Snapchat', url: 'https://www.snapchat.com/add/nugzzcrew', si: 'si-snapchat' },
  { name: 'Shop', url: 'https://officialnugzzcrew-shop.fourthwall.com', lucide: 'shopping-bag' },
  { name: 'Crew', url: 'https://socialclub.rockstargames.com/crew/official_nugzz_crew', lucide: 'users' },
];
---

<html lang="en">
    <head>
        <meta charset="utf-8" />
        <title>{title} | Official Nugzz Crew</title>
        <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0" />
        <link rel="icon" type="image/png" href="/Logo.png" />
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/simple-icons-font@v10/font/simple-icons.min.css" />
        <script src="https://unpkg.com/lucide@latest"></script>
    </head>
    <body class="bg-black text-white antialiased">
        <nav class="sticky top-0 z-50 bg-black/95 backdrop-blur-md border-b border-zinc-800 px-3 py-3 md:px-4">
            <div class="max-w-7xl mx-auto flex flex-col items-center gap-3 md:grid md:grid-cols-3 md:gap-0">
                
                <div class="flex md:justify-start w-full justify-center">
                    <a href="/" class="flex items-center gap-2 group transition-opacity hover:opacity-90">
                        <img src="/Logo.png" alt="Logo" class="w-6 h-6 md:w-9 md:h-9 object-contain" />
                        <span class="text-[clamp(11px,3vw,18px)] font-header text-gold uppercase tracking-tighter whitespace-nowrap">
                            Official Nugzz Crew
                        </span>
                    </a>
                </div>

                <div class="flex flex-col items-center gap-1.5 w-full">
                    <div class="flex justify-center gap-4 text-[9px] md:text-xs uppercase font-bold tracking-widest text-zinc-400">
                        <a href="/" class="hover:text-gold transition-colors">Home</a>
                        <a href="/gta" class="hover:text-gold transition-colors">GTA Bonuses</a>
                    </div>
                    <a 
                      href="https://www.youtube.com/@OfficialNugzzCrew/join?app=desktop&action=join" 
                      target="_blank" 
                      rel="noopener noreferrer"
                      class="text-[clamp(8px,2vw,10px)] text-gold-bright uppercase tracking-[0.2em] font-black text-center transition-all hover:text-white hover:scale-105 active:scale-95"
                    >
                        Join The Fam Bam Membership
                    </a>
                </div>

                <div class="flex justify-center md:justify-end gap-1.5 md:gap-3 w-full">
                    {socials.map((social) => (
                        <a href={social.url} target="_blank" rel="noopener noreferrer" class="group transition-transform hover:scale-110 active:scale-95">
                            <div class="w-4 h-4 md:w-6 md:h-6 flex items-center justify-center">
                                {social.si ? (
                                    <i class={`si ${social.si} text-[10px] md:text-base text-zinc-400 group-hover:text-gold transition-colors`}></i>
                                ) : (
                                    <i data-lucide={social.lucide} class="w-3.5 h-3.5 md:w-5 md:h-5 text-zinc-400 group-hover:text-gold transition-colors"></i>
                                )}
                            </div>
                        </a>
                    ))}
                </div>
            </div>
        </nav>
        
        <main class="relative z-10">
            <slot /> 
        </main>

        <footer class="p-10 text-center text-zinc-600 text-[10px] uppercase tracking-widest border-t border-zinc-900 mt-20">
            &copy; 2026 Official Nugzz Crew | Built for The Fam Bam
        </footer>

        <script is:inline>
          function initIcons() { if (window.lucide) window.lucide.createIcons(); }
          window.addEventListener('load', initIcons);
          document.addEventListener('astro:page-load', initIcons);
        </script>
    </body>
</html>

<style is:global>
    *, *::before, *::after {
        box-sizing: border-box;
    }

    body {
        margin: 0;
        padding: 0;
        min-height: 100vh;
        overflow-x: hidden; 
    }

    .si {
        display: flex !important;
        align-items: center !important;
        justify-content: center !important;
        line-height: 1 !important;
    }

    /* Custom color for the Join link to make it pop */
    .text-gold-bright {
        color: #ffcc00;
        text-shadow: 0 0 10px rgba(255, 204, 0, 0.2);
    }
</style>