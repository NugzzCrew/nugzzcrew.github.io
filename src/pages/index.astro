---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Home">
  <section class="max-w-4xl mx-auto py-12 md:py-20 px-4 md:px-6 text-center">
    
    <h1 class="text-[clamp(32px,10vw,60px)] mb-4 tracking-tighter uppercase font-black italic leading-[0.9]">
      Official Nugzz Crew
    </h1>
    
    <p class="text-base md:text-xl text-zinc-400 mb-10 italic max-w-2xl mx-auto">
      "Streaming, GTA Updates, and the best community in the game."
    </p>
    
    <!-- Video Wrapper: Ensuring Z-Index management -->
    <div class="relative aspect-video w-full rounded-xl md:rounded-2xl border border-zinc-800 mb-12 overflow-hidden bg-black shadow-[0_0_50px_-12px_rgba(212,175,55,0.3)]">
      <img 
        id="offline-placeholder" 
        src="/images/offline.png" 
        alt="Stream is currently offline" 
        style="display: block; width: 100%; height: 100%; object-fit: cover; position: absolute; top: 0; left: 0; z-index: 10;" 
      />
      <iframe 
        id="yt-video-frame" 
        src="about:blank" 
        allowfullscreen 
        style="display: none; width: 100%; height: 100%; position: relative; z-index: 20;">
      </iframe>
    </div>
  </section>
</MainLayout>

<script is:inline>
  function connectBot() {
      const ws = new WebSocket("wss://wss.officialnugzzcrew.com/");

      ws.onopen = () => {
          ws.send(JSON.stringify({ "request": "Subscribe", "events": { "general": ["Custom"] }, "id": "SubRequest" }));
          // ADDED: Force request for data immediately after subscribing
          setTimeout(() => {
            ws.send(JSON.stringify({ "request": "DoAction", "action": { "name": "Web_Request_Status" }, "id": "StatusCheck" }));
          }, 1000);
      };

      ws.onmessage = (event) => {
          console.log("RAW RECEIVED:", event.data);
          try {
              const msg = JSON.parse(event.data);
              // Handle both direct broadcast and wrapped event
              const data = msg.data ? msg.data : msg; 
              
              if (data.name === "LiveStatusUpdate") {
                  const videoFrame = document.getElementById('yt-video-frame');
                  const placeholderImg = document.getElementById('offline-placeholder');
                  
                  if (data.isLive === true) {
                      videoFrame.style.display = 'block';
                      videoFrame.src = `https://www.youtube.com/embed/${data.videoId}?autoplay=1&mute=1`;
                      placeholderImg.style.display = 'none';
                  } else {
                      videoFrame.style.display = 'none';
                      videoFrame.src = "about:blank";
                      placeholderImg.style.display = 'block';
                  }
              }
          } catch (e) {}
      };
      ws.onclose = () => setTimeout(connectBot, 5000);
  }
  window.addEventListener('load', connectBot);
</script>