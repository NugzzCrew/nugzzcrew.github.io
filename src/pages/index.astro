---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Home">
  <section class="max-w-4xl mx-auto py-20 px-6 text-center">
    <h1 class="text-6xl mb-4 tracking-wider">
      Official Nugzz Crew
    </h1>
    <p class="text-xl text-zinc-400 mb-10 italic">"Streaming, GTA Updates, and the best community in the game."</p>
    
    <!-- Stream Container -->
    <div id="stream-container" class="relative aspect-video w-full rounded-2xl border border-zinc-800 mb-12 overflow-hidden bg-black shadow-[0_0_50px_-12px_rgba(212,175,55,0.3)]">
      
      <!-- 1. The Offline Image (Always in the background) -->
      <div id="offline-view" class="absolute inset-0 z-0">
        <img src="/offline.png" alt="Official Nugzz Crew Offline" class="w-full h-full object-cover opacity-60" />
      </div>

      <!-- 2. The YouTube Embed (Starts hidden) -->
      <iframe 
        id="yt-player"
        class="absolute top-0 left-0 w-full h-full z-10 opacity-0 transition-opacity duration-1000 pointer-events-none"
        src="https://www.youtube.com/embed/live_stream?channel=UCYNmnbEgm3G0m4avmwz_4Eg&autoplay=1&mute=1" 
        title="Official Nugzz Crew Live Stream" 
        frameborder="0" 
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" 
        allowfullscreen>
      </iframe>

      <!-- 3. Status Badge -->
      <div class="absolute bottom-6 left-6 z-20 flex items-center gap-2 bg-black/70 backdrop-blur-md px-4 py-2 rounded-full border border-white/10">
        <span id="live-indicator" class="w-2 h-2 bg-zinc-500 rounded-full"></span>
        <span id="live-text" class="text-[10px] uppercase font-black tracking-widest text-zinc-400">Checking Status...</span>
      </div>
    </div>

    <div class="grid md:grid-cols-2 gap-6 mt-12">
        <a href="/gta" class="p-8 bg-zinc-900 border border-zinc-800 rounded-2xl hover:border-gold transition-all group text-left">
          <h2 class="text-2xl group-hover:text-gold-bright transition-colors uppercase">GTA Weekly Updates &rarr;</h2>
          <p class="text-zinc-500 mt-2">Get the latest on bonuses, car meets, and robberies.</p>
        </a>
  
        <div class="p-8 bg-zinc-900 border border-zinc-800 rounded-2xl text-left">
          <h2 class="text-2xl uppercase font-header text-gold">The Fam Bam</h2>
          <p class="text-zinc-500 mt-2">Catch every live stream and join the best community on YouTube.</p>
        </div>
      </div>
  </section>
</MainLayout>

<script is:inline>
  async function checkLiveStatus() {
    const channelId = 'UCYNmnbEgm3G0m4avmwz_4Eg';
    const player = document.getElementById('yt-player');
    const indicator = document.getElementById('live-indicator');
    const statusText = document.getElementById('live-text');
    const offlineView = document.getElementById('offline-view');

    try {
      // Direct fetch check
      const response = await fetch(`https://www.youtube.com/embed/live_stream?channel=${channelId}`);
      const text = await response.text();

      // Check for 'offline' or 'unavailable' keywords
      if (text.includes('LIVE_STREAM_OFFLINE') || text.includes('video-unavailable')) {
        statusText.innerText = 'Stream Offline';
        indicator.classList.replace('bg-red-600', 'bg-zinc-500');
        indicator.classList.remove('animate-pulse');
      } else {
        // Switch to Live State
        player.classList.remove('opacity-0', 'pointer-events-none');
        player.classList.add('opacity-100');
        indicator.classList.remove('bg-zinc-500');
        indicator.classList.add('bg-red-600', 'animate-pulse');
        statusText.innerText = 'Live Now';
        statusText.classList.replace('text-zinc-400', 'text-white');
        offlineView.classList.add('hidden');
      }
    } catch (error) {
      statusText.innerText = 'Stream Offline';
    }
  }

  checkLiveStatus();
  // Checks every 2 minutes to see if you've gone live
  setInterval(checkLiveStatus, 120000);
</script>