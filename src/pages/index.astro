---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Home">
  <section class="max-w-4xl mx-auto py-20 px-6 text-center">
    <h1 class="text-6xl font-black uppercase tracking-tighter text-orange-500 mb-4">
      Official Nugzz Crew
    </h1>
    <p class="text-xl text-zinc-400 mb-10">Streaming, GTA Updates, and the best community in the game.</p>
    
    <div class="aspect-video w-full bg-zinc-900 rounded-2xl border border-zinc-800 flex items-center justify-center mb-12 overflow-hidden shadow-2xl">
      <!-- Replace YOUR_VIDEO_ID with an actual YouTube ID later -->
      <iframe width="100%" height="100%" src="https://www.youtube.com/embed/live_stream?channel=OfficialNugzzCrew" title="YouTube video player" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" allowfullscreen></iframe>
    </div>

    <div class="grid md:grid-cols-2 gap-6">
      <a href="/gta" class="p-8 bg-zinc-900 border border-zinc-800 rounded-2xl hover:border-orange-500 transition-all group text-left">
        <h2 class="text-2xl font-bold group-hover:text-orange-500 transition-colors">GTA Weekly Updates &rarr;</h2>
        <p class="text-zinc-500 mt-2">Get the latest on bonuses, car meets, and robberies.</p>
      </a>
      <div class="p-8 bg-zinc-900 border border-zinc-800 rounded-2xl text-left">
        <h2 class="text-2xl font-bold">Join The Fam Bam</h2>
        <p class="text-zinc-500 mt-2">Subscribe on YouTube to catch every live stream.</p>
      </div>
    </div>
  </section>
</MainLayout>