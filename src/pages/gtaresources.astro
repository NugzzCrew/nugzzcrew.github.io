---
import MainLayout from '../layouts/MainLayout.astro';

// Fallback defaults while automated compiler actions finalize
const defaultZone = "Locating Active Vector...";
const defaultDetails = "Polling real-time scraping anchors from gtalens server maps...";

const fallbackWeapons = [
  { name: "Compact EMP Launcher", discount: "-40% OFF" },
  { name: "Military Rifle", discount: "-10% OFF" },
  { name: "Precision Rifle", discount: "-10% OFF" },
  { name: "Homing Launcher", discount: "-10% OFF" },
  { name: "Pump Shotgun", discount: "-10% OFF" },
  { name: "Pool Cue", discount: "-10% OFF" }
];
---

<MainLayout title="GTA Resources & Tracker">
  <div class="max-w-5xl mx-auto px-4 py-12">
    
    <div class="mb-10 text-center">
      <h1 class="text-4xl font-header text-gold uppercase tracking-tighter mb-2">GTA Resource Hub</h1>
      <p class="text-zinc-400 uppercase text-xs tracking-[0.2em]">Live Gun Van Tracking Terminal for the Fam Bam</p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
      
      <div class="lg:col-span-6 space-y-6">
        <div class="bg-zinc-900/40 p-6 rounded-3xl border border-zinc-800 space-y-6">
          <div class="flex items-center justify-between border-b border-zinc-800 pb-4">
            <div>
              <span class="text-[10px] text-zinc-500 uppercase font-black tracking-widest block">System Diagnostic</span>
              <span class="text-emerald-400 font-bold text-sm uppercase flex items-center gap-1.5">
                <span class="w-2 h-2 bg-emerald-400 rounded-full animate-pulse"></span> Tracking Active
              </span>
            </div>
            <span class="font-mono text-zinc-500 text-[10px] uppercase">Source: GTALens</span>
          </div>

          <div>
            <label class="block text-[10px] text-zinc-500 uppercase font-black mb-1">Target Sector:</label>
            <div id="displayZone" class="text-xl font-header text-white uppercase tracking-tight">{defaultZone}</div>
          </div>

          <div>
            <label class="block text-[10px] text-zinc-500 uppercase font-black mb-1">Position Landmarks:</label>
            <p id="displayDetails" class="text-sm text-zinc-400 leading-relaxed">{defaultDetails}</p>
          </div>

          <div class="relative aspect-video w-full bg-black border border-zinc-800 rounded-2xl overflow-hidden group flex items-center justify-center">
            <img 
              id="vanMapImage" 
              src="" 
              alt="Gun Van Location Map" 
              class="w-full h-full object-cover opacity-0 transition-transform transition-opacity duration-700 ease-out group-hover:scale-150"
            />
            
            <div class="absolute inset-x-0 top-1/2 border-t border-zinc-800/40 pointer-events-none"></div>
            <div class="absolute inset-y-0 left-1/2 border-l border-zinc-800/40 pointer-events-none"></div>
          </div>
        </div>
      </div>

      <div class="lg:col-span-6 space-y-6">
        <div class="bg-black border-2 border-zinc-800 rounded-3xl p-6 space-y-4">
          <div>
            <h2 class="text-xl font-header text-gold uppercase tracking-tight">Active Gun Surplus</h2>
            <p class="text-[10px] text-zinc-500 uppercase tracking-widest">Wholesale Rotation Modifiers</p>
          </div>

          <div id="weaponsContainer" class="space-y-2">
            {fallbackWeapons.map(w => (
              <div class="flex justify-between items-center p-3 bg-zinc-900/20 border border-zinc-800/60 rounded-xl">
                <span class="text-sm font-bold text-white">{w.name}</span>
                <span class="font-mono text-emerald-400 text-xs font-black px-2 py-0.5 bg-emerald-500/10 rounded">{w.discount}</span>
              </div>
            ))}
          </div>

          <div class="pt-2 border-t border-zinc-800/60">
            <span class="text-[10px] text-zinc-500 font-black uppercase block mb-2 tracking-wider">Gear & Combat Support</span>
            <div class="grid grid-cols-2 gap-2 text-xs text-zinc-400 font-medium">
              <div class="p-2.5 bg-zinc-900/30 border border-zinc-800/60 rounded-xl flex justify-between"><span>Molotovs</span><span class="text-gold">-10%</span></div>
              <div class="p-2.5 bg-zinc-900/30 border border-zinc-800/60 rounded-xl flex justify-between"><span>Tear Gas</span><span class="text-gold">-10%</span></div>
              <div class="p-2.5 bg-zinc-900/30 border border-zinc-800/60 rounded-xl flex justify-between"><span>Proximity Mine</span><span class="text-gold">-10%</span></div>
              <div class="p-2.5 bg-zinc-900/30 border border-zinc-800/60 rounded-xl flex justify-between"><span>Body Armor</span><span class="text-gold">-10%</span></div>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>
</MainLayout>

<script is:inline>
  async function fetchLiveMap() {
    try {
      const res = await fetch('/api/gunvan.json');
      if (!res.ok) return;
      const data = await res.json();
      
      // Update text fields dynamically
      document.getElementById('displayZone').textContent = data.zone;
      document.getElementById('displayDetails').textContent = data.description;
      
      // Dynamically switch the map image source to match the active locationId
      if (data.locationId) {
        const mapImg = document.getElementById('vanMapImage');
        if (mapImg) {
          mapImg.src = `/images/gunvan/map_${data.locationId}.jpg`;
          
          mapImg.onload = function() {
            mapImg.classList.remove('opacity-0');
            mapImg.classList.add('opacity-80');
          };
        }
      }
    } catch (e) {
      console.error("Error running tracking engine interface synchronization loops:", e);
    }
  }

  fetchLiveMap();
</script>