---
import MainLayout from '../layouts/MainLayout.astro';
import gtaData from '../data/gta-weekly.json';

// Fallback in case eventTitle isn't in the JSON yet, defaults to a clean theme title
const eventTitle = gtaData.eventTitle || "Hands On Car Wash Takeover";
---

<MainLayout title="GTA Weekly & GTA+">
  <div class="max-w-7xl mx-auto py-12 px-4 md:px-6 space-y-16">
    
    <section>
        <div class="flex flex-col md:flex-row justify-between gap-8 items-start">
            <div>
                <!-- FIXED: Header is now completely dynamic based on the active event -->
                <h1 class="text-[clamp(40px,6vw,80px)] font-black italic uppercase leading-[0.8] text-white tracking-tighter">
                  {eventTitle}
                </h1>
                <p class="text-zinc-500 font-bold uppercase tracking-widest mt-4">Event available through {gtaData.weekEnding}</p>
            </div>
            <div class="bg-gold p-6 rounded-2xl text-black max-w-md shadow-[0_0_30px_-5px_rgba(212,175,55,0.4)]">
                <p class="text-[10px] font-black uppercase tracking-[0.2em] mb-1 opacity-70">Weekly Challenge</p>
                <p class="font-black italic text-lg leading-tight uppercase">{gtaData.weeklyChallenge}</p>
            </div>
        </div>
    </section>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="bg-zinc-900/30 border border-zinc-800 p-5 rounded-2xl flex flex-col justify-between">
            <div>
                <span class="text-[9px] text-red-500 font-black uppercase tracking-wider block mb-1">Intercepted Ledger</span>
                <h3 class="text-white font-header text-lg uppercase tracking-tight">FIB Priority File</h3>
            </div>
            <div class="mt-4 p-3 bg-red-950/20 border border-red-900/40 rounded-xl text-center">
                <p class="text-zinc-400 text-xs font-mono font-bold">{gtaData.fibFile}</p>
            </div>
        </div>

        <div class="bg-zinc-900/30 border border-zinc-800 p-5 rounded-2xl flex flex-col justify-between">
            <div>
                <span class="text-[9px] text-gold font-black uppercase tracking-wider block mb-1">Mobile Black Market</span>
                <h3 class="text-white font-header text-lg uppercase tracking-tight">Gun Van Primary Stock</h3>
            </div>
            <div class="mt-3 space-y-1.5">
                {gtaData.gunVan.map(item => (
                    <div class="bg-black/40 border border-zinc-800 px-3 py-1.5 rounded-lg text-[11px] font-mono font-bold text-zinc-300">
                        • {item}
                    </div>
                ))}
            </div>
        </div>

        <div class="bg-zinc-900/30 border border-zinc-800 p-5 rounded-2xl flex flex-col justify-between">
            <div>
                <span class="text-[9px] text-blue-400 font-black uppercase tracking-wider block mb-1">Time Trial Node</span>
                <h3 class="text-white font-header text-lg uppercase tracking-tight">Race Vectors</h3>
            </div>
            <div class="mt-3 space-y-1 text-[11px] font-bold uppercase text-zinc-400">
                <div><span class="text-white">Regular:</span> {gtaData.timeTrials.regular}</div>
                <div><span class="text-blue-400">HSW Tier:</span> {gtaData.timeTrials.hsw}</div>
                <div><span class="text-gold">Premium:</span> {gtaData.timeTrials.premium}</div>
            </div>
        </div>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-3">
        {gtaData.bonuses.map(bonus => (
            <div class="bg-zinc-900 border border-zinc-800 p-4 rounded-xl text-center hover:border-gold transition-colors flex flex-col justify-center items-center">
                <p class="text-gold font-black text-2xl tracking-tighter">{bonus.value}</p>
                <p class="text-[9px] text-zinc-400 font-bold uppercase mt-1 leading-tight">{bonus.name}</p>
            </div>
        ))}
    </div>

    <div class="grid md:grid-cols-2 gap-6">
        <div class="bg-zinc-900/50 border border-zinc-800 p-6 rounded-2xl">
            <h3 class="text-white font-black uppercase italic mb-4 flex items-center gap-2">
                <i data-lucide="gift" class="text-gold w-5 h-5"></i> Login Rewards
            </h3>
            <ul class="grid grid-cols-1 sm:grid-cols-2 gap-2">
                {gtaData.loginRewards.map(reward => (
                    <li class="bg-black/40 border border-zinc-800 px-4 py-2 rounded-lg text-white text-[11px] font-bold uppercase tracking-tight">• {reward}</li>
                ))}
            </ul>
        </div>
        <div class="bg-gold/5 border border-gold/20 p-6 rounded-2xl">
            <h3 class="text-gold font-black uppercase italic mb-4 flex items-center gap-2">
                <i data-lucide="shopping-bag" class="text-gold w-5 h-5"></i> Purchase Unlocks
            </h3>
            <div class="space-y-2">
                {gtaData.purchaseUnlocks.map(item => (
                    <div class="flex justify-between items-center bg-black/40 p-3 rounded-lg border border-gold/10">
                        <p class="text-[10px] text-zinc-400 font-bold uppercase">{item.action}</p>
                        <p class="text-[11px] text-gold font-black uppercase tracking-tighter">{item.reward}</p>
                    </div>
                ))}
            </div>
        </div>
    </div>

    <div class="grid md:grid-cols-3 gap-8">
        <div class="space-y-4">
            <h2 class="text-xl font-black uppercase italic text-white flex items-center gap-2 border-l-4 border-gold pl-3">
                Salvage Yard
            </h2>
            {gtaData.salvageYard.map(car => (
                <div class="bg-zinc-900 p-4 rounded-xl border border-zinc-800 flex justify-between items-center">
                    <div>
                        <p class="text-[9px] text-zinc-500 font-bold uppercase">{car.robbery}</p>
                        <p class="text-white font-bold text-sm leading-tight">{car.name}</p>
                    </div>
                    <span class={`text-[8px] font-black px-2 py-1 rounded uppercase tracking-tighter ${car.type === 'CLAIMABLE' ? 'bg-gold text-black animate-pulse' : 'bg-zinc-800 text-gold'}`}>{car.type}</span>
                </div>
            ))}
        </div>

        <div class="space-y-4">
            <h2 class="text-xl font-black uppercase italic text-white flex items-center gap-2 border-l-4 border-gold pl-3">
                Showrooms
            </h2>
            <div class="bg-zinc-900 p-6 rounded-xl border border-zinc-800 space-y-4 h-[calc(100%-3rem)]">
                <div>
                    <p class="text-gold font-black text-[10px] uppercase tracking-widest mb-2">PDM & Luxury Autos Inventory</p>
                    <ul class="text-white text-[11px] font-bold space-y-1.5 uppercase tracking-tight">
                        {[...gtaData.simeonVehicles, ...gtaData.luxuryAutos].map(car => <li>• {car}</li>)}
                    </ul>
                </div>
            </div>
        </div>

        <div class="space-y-4">
            <h2 class="text-xl font-black uppercase italic text-white flex items-center gap-2 border-l-4 border-gold pl-3">
                LS Car Meet
            </h2>
            <div class="bg-zinc-900 p-6 rounded-xl border border-zinc-800 space-y-4">
                <div>
                    <p class="text-gold font-black text-[10px] uppercase tracking-widest mb-1">Prize Ride: {gtaData.prizeRide}</p>
                    <p class="text-zinc-500 text-[10px] uppercase font-bold leading-tight">{gtaData.lsCarMeet.prizeRideRequirement}</p>
                </div>
                <div>
                    <p class="text-gold font-black text-[10px] uppercase tracking-widest mb-2">Test Track Fleet</p>
                    <ul class="text-white text-[11px] font-bold space-y-1 uppercase">
                        {gtaData.lsCarMeet.testTrack.map(car => <li>• {car}</li>)}
                        <li class="text-blue-400 italic font-black mt-1">Premium HSW: {gtaData.lsCarMeet.hsw}</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>

    <section class="bg-zinc-900/50 rounded-3xl p-8 border border-zinc-800">
        <h2 class="text-2xl font-black uppercase italic text-white mb-8 border-l-4 border-gold pl-4">Limited Time Discounts</h2>
        <div class="grid md:grid-cols-3 gap-12">
            <div>
                <p class="text-gold font-black text-lg mb-4 italic">50% OFF</p>
                <ul class="text-white text-[11px] font-bold space-y-2 uppercase tracking-tighter">
                    {gtaData.discounts.fifty.map(item => <li class="border-b border-white/5 pb-1">{item}</li>)}
                </ul>
            </div>
            <div>
                <p class="text-gold font-black text-lg mb-4 italic">40% OFF</p>
                <ul class="text-white text-[11px] font-bold space-y-2 uppercase tracking-tighter">
                    {gtaData.discounts.forty.map(item => <li class="border-b border-white/5 pb-1">{item}</li>)}
                </ul>
            </div>
            <div>
                <p class="text-gold font-black text-lg mb-4 italic">30% OFF</p>
                <ul class="text-white text-[11px] font-bold space-y-2 uppercase tracking-tighter">
                    {gtaData.discounts.thirty.map(item => <li class="border-b border-white/5 pb-1">{item}</li>)}
                </ul>
            </div>
        </div>
    </section>

    <section class="relative rounded-[2.5rem] overflow-hidden bg-black border border-gold/30">
        <div class="bg-zinc-900 p-8 border-b border-gold/20">
            <div class="flex flex-col md:flex-row justify-between items-center gap-4">
                <div>
                    <h2 class="text-4xl md:text-5xl font-black italic uppercase tracking-tighter text-white">GTA+ <span class="text-gold">Rewards</span></h2>
                    <p class="text-gold font-bold uppercase tracking-widest text-[10px] mt-1 italic">{gtaData.gtaPlus.duration}</p>
                </div>
                <div class="bg-gold text-black px-6 py-2 rounded-full font-black uppercase text-xs">
                    Premium Member Benefits
                </div>
            </div>
        </div>

        <div class="p-8 md:p-12 space-y-12">
            <div class="grid md:grid-cols-2 gap-8">
                <div class="space-y-4">
                    <p class="text-gold font-black uppercase tracking-widest text-[10px]">Free Vehicles & Paints</p>
                    <div class="grid grid-cols-1 gap-2">
                        {gtaData.gtaPlus.freeVehicles.map(v => <div class="bg-zinc-900 p-4 rounded-xl border border-zinc-800 text-white text-xs font-bold uppercase">• {v}</div>)}
                    </div>
                </div>
                <div class="space-y-4">
                    <p class="text-gold font-black uppercase tracking-widest text-[10px]">Free Clothing</p>
                    <div class="grid grid-cols-1 gap-2">
                        {gtaData.gtaPlus.clothing.map(c => <div class="bg-zinc-900 p-4 rounded-xl border border-zinc-800 text-white text-xs font-bold uppercase">• {c}</div>)}
                    </div>
                </div>
            </div>

            <div class="grid md:grid-cols-2 gap-8">
                <div class="space-y-4">
                    <p class="text-gold font-black uppercase tracking-widest text-[10px]">Active Multipliers & Discounts</p>
                    <div class="grid grid-cols-1 gap-2">
                        {gtaData.gtaPlus.bonuses.map(b => <div class="bg-gold/10 p-4 rounded-xl border border-gold/20 text-white text-xs font-bold uppercase tracking-tight">{b}</div>)}
                        {gtaData.gtaPlus.discounts.map(d => <div class="bg-gold p-3 rounded-xl text-black font-black text-sm uppercase text-center mt-2">{d}</div>)}
                    </div>
                </div>
                <div class="bg-zinc-900 p-6 rounded-2xl border border-zinc-800">
                    <p class="text-gold font-black uppercase tracking-widest text-[10px] mb-4 text-center">Vinewood Club Showroom (20% OFF)</p>
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-4 gap-y-1">
                        {gtaData.gtaPlus.vinewoodShowroom.map(car => <li class="text-white text-[10px] font-bold list-none uppercase border-b border-white/5 pb-1">• {car}</li>)}
                    </div>
                </div>
            </div>

            <div class="grid md:grid-cols-2 gap-12 pt-8 border-t border-zinc-800">
                <div class="space-y-6">
                    <h3 class="text-xl font-black italic uppercase text-gold tracking-tighter">Member Persistent Perks</h3>
                    <div class="grid grid-cols-1 gap-y-3">
                        {gtaData.gtaPlus.persistent.map(perk => (
                            <div class="flex items-center gap-3 text-zinc-400">
                                <i data-lucide="check-circle" class="w-4 h-4 text-gold"></i>
                                <span class="text-[10px] font-bold uppercase">{perk}</span>
                            </div>
                        ))}
                    </div>
                </div>
                <div class="space-y-6">
                    <h3 class="text-xl font-black italic uppercase text-gold tracking-tighter">Vinewood Club Access</h3>
                    <div class="grid grid-cols-1 gap-y-4">
                        {gtaData.gtaPlus.vinewoodClub.map(benefit => (
                            <div class="bg-white/5 p-4 rounded-xl border border-white/10">
                                <p class="text-white text-[10px] font-bold uppercase leading-tight">{benefit}</p>
                            </div>
                        ))}
                    </div>
                </div>
            </div>
        </div>
    </section>

  </div>
</MainLayout>

<script is:inline>
  function initGtaIcons() {
    if (window.lucide) {
      window.lucide.createIcons();
    }
  }
  window.addEventListener('load', initGtaIcons);
  document.addEventListener('astro:page-load', initGtaIcons);
</script>