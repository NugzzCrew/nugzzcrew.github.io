---
import MainLayout from '../layouts/MainLayout.astro';
import gtaData from '../data/gta-weekly.json';
---

<MainLayout title="GTA Weekly & GTA+">
  <div class="max-w-7xl mx-auto py-12 px-4 md:px-6 space-y-16">
    <section>
        <h1 class="text-6xl font-black italic uppercase text-white">{gtaData.eventTitle}</h1>
        <p class="text-zinc-400">Available through {gtaData.weekEnding}</p>
    </section>

    <!-- Time Trials Section -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="bg-zinc-900 p-6 rounded-xl">
            <h3 class="text-gold font-bold uppercase">Time Trial</h3>
            <p class="text-white">{gtaData.timeTrials?.regular}</p>
        </div>
        <div class="bg-zinc-900 p-6 rounded-xl">
            <h3 class="text-blue-400 font-bold uppercase">HSW Time Trial</h3>
            <p class="text-white">{gtaData.timeTrials?.hsw}</p>
        </div>
        <div class="bg-zinc-900 p-6 rounded-xl">
            <h3 class="text-gold font-bold uppercase">Premium Race</h3>
            <p class="text-white">{gtaData.timeTrials?.premium}</p>
        </div>
    </div>

    <!-- Weekly Challenge -->
    <div class="bg-gold p-8 rounded-2xl text-black">
        <h2 class="font-black uppercase">Weekly Challenge</h2>
        <p class="text-lg">{gtaData.weeklyChallenge}</p>
    </div>

    <!-- Salvage Yard -->
    <div class="grid md:grid-cols-3 gap-4">
        {gtaData.salvageYard?.map(car => (
            <div class="bg-zinc-800 p-4 rounded-lg text-white">{car.name}</div>
        ))}
    </div>
  </div>
</MainLayout>